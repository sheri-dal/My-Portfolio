# SMTP mail delivery for the contact form
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password

# Optional. Defaults to SMTP_USER if omitted.
CONTACT_TO_EMAIL=hello@yourdomain.dev
CONTACT_FROM_EMAIL=hello@yourdomain.dev

# Optional server port
PORT=4000
